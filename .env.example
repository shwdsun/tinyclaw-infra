# ── Required ──────────────────────────────────────────────────────────

# API key for the auth proxy (external access to TinyClaw API)
API_KEY=change-me-to-a-random-string

# ── AI Provider (at least one required) ──────────────────────────────

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Channel bot tokens (enable with: docker compose --profile <name> up)

# Discord: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Telegram: message @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# WhatsApp: no token needed, scan QR code after starting

# ── Optional ─────────────────────────────────────────────────────────

# Path to tinyclaw repo (default: ../tinyclaw)
# TINYCLAW_PATH=../tinyclaw

# Port for the auth proxy (default: 8080)
# PROXY_PORT=8080
