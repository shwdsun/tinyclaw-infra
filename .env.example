# ── Required ──────────────────────────────────────────────────
API_KEY=change-me-to-a-random-string

# ── AI providers (at least one required) ─────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Channel bot tokens (enable via --profile) ────────────────
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
# WhatsApp: no token needed, scan QR after starting

