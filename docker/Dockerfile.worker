FROM node:20-slim

RUN apt-get update && \
    apt-get install -y python3 make g++ git && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -u 1001 worker

WORKDIR /app
COPY worker/ .

RUN mkdir -p /workspace && \
    chown -R worker:worker /app /workspace

USER worker

EXPOSE 9100

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s \
    CMD node -e "fetch('http://localhost:9100/health').then(r=>{if(!r.ok)throw 1}).catch(()=>process.exit(1))"

CMD ["node", "index.js"]
