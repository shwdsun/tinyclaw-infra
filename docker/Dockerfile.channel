FROM node:20-slim

RUN apt-get update && \
    apt-get install -y python3 make g++ && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=tinyclaw package.json ./
COPY --from=tinyclaw packages/ packages/
RUN npm install

COPY --from=tinyclaw . .
RUN npm run build

ENV TINYCLAW_API_PORT=3777

ARG CHANNEL=discord
ENV CHANNEL_SCRIPT=packages/channels/dist/${CHANNEL}.js

CMD ["sh", "-c", "node $CHANNEL_SCRIPT"]
